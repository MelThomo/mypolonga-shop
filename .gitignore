# Ignore working/source files — only shop files go to GitHub
*.py
*.pdf
*.md
*.pptx
*.log

# JSON files ignored by default — but allow netlify functions package files
*.json
!netlify/functions/package.json
!netlify/functions/package-lock.json

# Exclude node_modules
node_modules/

# Raw/source images (keep only the optimised /images/ folder)
*.png
*.jpg
*.webp
!images/*.webp
!images/*.jpg

# Misc
*.txt
__pycache__/
.DS_Store
